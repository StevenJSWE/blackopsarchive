---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import NavBar from '../components/NavBar.astro';

const articles = await getCollection('articles');
const confirmedCount = articles.filter(a => a.data.status === 'confirmed').length;
const allegedCount = articles.filter(a => a.data.status === 'alleged').length;
const disputedCount = articles.filter(a => a.data.status === 'disputed').length;

const STATUS_CONFIG: Record<string, { label: string; color: string }> = {
  confirmed: { label: 'CONFIRMED', color: '#39ff14' },
  alleged:   { label: 'ALLEGED',   color: '#cc0000' },
  disputed:  { label: 'DISPUTED',  color: '#f59e0b' },
};
---

<BaseLayout title="Archive">
  <NavBar />
  <main class="max-w-3xl mx-auto px-6 py-12">

    <div class="mb-10">
      <span class="inline-block border-2 border-classified-red text-classified-red text-[10px] font-stencil tracking-[0.25em] px-2 py-0.5 -rotate-1 mb-3 opacity-90">DECLASSIFIED</span>
      <h1 class="font-stencil text-4xl text-classified-green tracking-wide mb-2">Archive</h1>
      <p class="font-mono text-[11px] text-[#4a4a4a] tracking-widest uppercase">
        {confirmedCount} confirmed · {allegedCount} alleged · {articles.length} total operations
      </p>
    </div>

    <!-- Filter tabs -->
    <div class="flex gap-2 mb-8 flex-wrap">
      <button
        data-filter="all"
        class="filter-btn text-[10px] font-mono uppercase tracking-widest px-3 py-1.5 border cursor-pointer transition-all duration-200"
        style="border-color:#39ff14; color:#39ff14; background:rgba(57,255,20,0.07);"
      >
        ALL ({articles.length})
      </button>
      <button
        data-filter="confirmed"
        class="filter-btn text-[10px] font-mono uppercase tracking-widest px-3 py-1.5 border cursor-pointer transition-all duration-200"
        style="border-color:#4a4a4a; color:#707070;"
      >
        CONFIRMED ({confirmedCount})
      </button>
      <button
        data-filter="alleged"
        class="filter-btn text-[10px] font-mono uppercase tracking-widest px-3 py-1.5 border cursor-pointer transition-all duration-200"
        style="border-color:#4a4a4a; color:#707070;"
      >
        ALLEGED ({allegedCount})
      </button>
      {disputedCount > 0 && (
        <button
          data-filter="disputed"
          class="filter-btn text-[10px] font-mono uppercase tracking-widest px-3 py-1.5 border cursor-pointer transition-all duration-200"
          style="border-color:#4a4a4a; color:#707070;"
        >
          DISPUTED ({disputedCount})
        </button>
      )}
    </div>

    <!-- Article list -->
    <ul class="divide-y divide-terminal-grey" id="archive-list">
      {articles.map(article => {
        const statusCfg = STATUS_CONFIG[article.data.status] ?? STATUS_CONFIG.alleged;
        return (
          <li data-status={article.data.status}>
            <a href={`/articles/${article.id}`} class="group block py-5 pl-4 border-l-2 border-transparent hover:border-classified-green transition-all duration-200">
              <div class="flex items-center gap-3 mb-1 flex-wrap">
                <p class="text-[10px] text-classified-green uppercase tracking-widest font-mono">
                  {article.data.era} · {article.data.country.join(', ')}
                </p>
                <span
                  class="text-[9px] font-mono tracking-widest px-1.5 py-0.5 border"
                  style={`color:${statusCfg.color}; border-color:${statusCfg.color};`}
                >
                  {statusCfg.label}
                </span>
                <span class="text-[9px] font-mono text-[#4a4a4a]">
                  {article.data.agency.join(' / ')}
                </span>
              </div>
              <h2 class="text-xl font-stencil text-[#e5e5e5] group-hover:text-classified-green transition-colors duration-200">
                {article.data.title}
              </h2>
              <p class="text-[#707070] text-sm mt-1 font-mono">{article.data.summary}</p>
            </a>
          </li>
        );
      })}
    </ul>

  </main>
</BaseLayout>

<script>
  const STATUS_COLORS: Record<string, string> = {
    all:       '#39ff14',
    confirmed: '#39ff14',
    alleged:   '#cc0000',
    disputed:  '#f59e0b',
  };

  const buttons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const items   = document.querySelectorAll<HTMLLIElement>('#archive-list li');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter ?? 'all';
      const activeColor = STATUS_COLORS[filter];

      buttons.forEach(b => {
        const c = STATUS_COLORS[b.dataset.filter ?? 'all'];
        if (b === btn) {
          b.style.borderColor = c;
          b.style.color = c;
          b.style.background = `${c}12`;
        } else {
          b.style.borderColor = '#4a4a4a';
          b.style.color = '#707070';
          b.style.background = 'transparent';
        }
      });

      items.forEach(item => {
        item.style.display = (filter === 'all' || item.dataset.status === filter) ? '' : 'none';
      });
    });
  });
</script>
